---
// Import the necessary components
import MainLayout from "@/layouts/MainLayout.astro";
import HeroSection from "@components/sections/landing/HeroSection.astro";
import HeroSectionAlt from "@components/sections/landing/HeroSectionAlt.astro";
import ClientsSection from "@components/sections/landing/ClientsSection.astro";
import FeaturesGeneral from "@components/sections/features/FeaturesGeneral.astro";
import FeaturesNavs from "@components/sections/features/FeaturesNavs.astro";
import TestimonialsSection from "@components/sections/testimonials/TestimonialsSection.astro";
import PricingSection from "@components/sections/pricing/PricingSection.astro";
import FAQ from "@components/sections/misc/FAQ.astro";
import AnnouncementBanner from "@components/ui/banners/AnnouncementBanner.astro";
import heroImage from "@images/03 Post - The Content Studio.png";
import faqs from "@data/faqs.json";
import features from "@data/features.json";
import pricing from "@data/pricing.json";
import featureImage from "@images/07 Post - The Content Studio.png";
import construction from "@images/construction-image.avif";
import tools from "@images/Modelo - Camiseta Color HEX FFFFFF o HEX F5F5F5 - Logo Color HEX 3C3C3C.jpg";
import dashboard from "@images/dashboard-image.avif";

const avatarSrcs: Array<string> = [
  "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1531927557220-a9e23c1e4794?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1541101767792-f9b2b1c4f127?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&&auto=format&fit=facearea&facepad=3&w=300&h=300&q=80",
  "https://images.unsplash.com/photo-1492562080023-ab3db95bfbce?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=300&h=300&q=80",
];
---

<MainLayout>
  <HeroSection
    title=`Estudio fotográfico profesional <span class="text-yellow-500 dark:text-yellow-400">Content Studio</span>`
    subTitle="Reserva tu sesión en nuestro amplio y versátil espacio, equipado con lo último en tecnología para todo tipo de proyectos fotográficos."
    primaryBtn="Reserva ahora"
    primaryBtnURL="/reservas"
    secondaryBtn="Ver galería"
    secondaryBtnURL="/galeria"
    withReview={true}
    avatars={avatarSrcs}
    rating=`<span class="font-bold">4.9</span> / 5`
    starCount={5}
    reviews=`Basado en más de <span class="font-bold">1000</span> opiniones`
    src={heroImage}
    alt="Interior de un estudio fotográfico profesional con equipos de iluminación y cámaras"
  />

  <ClientsSection
    title="Confianza de profesionales y marcas líderes"
    subTitle="Experimenta la calidad elegida por los mejores fotógrafos y agencias creativas."
  />

  <FeaturesGeneral
    title="Equipamiento de última generación"
    subTitle="En Content Studio, ofrecemos soluciones para todos los desafíos de la fotografía profesional. Desde iluminación avanzada hasta fondos versátiles, estamos dedicados a ayudarte a lograr tus visiones creativas."
    src={featureImage}
    alt="Equipos fotográficos profesionales en Content Studio"
    features={features}
  />

  <FeaturesNavs
    title=`Descubre las <span class="text-yellow-500 dark:text-yellow-400">ventajas</span> de Content Studio para tus necesidades fotográficas.`
    tabs={[
      {
        heading: "Equipos de vanguardia",
        content: "Potencia tus proyectos con los equipos más avanzados de Content Studio. Experimenta una eficiencia mejorada en la producción fotográfica con nuestras soluciones de iluminación y cámaras de última generación.",
        svg: "tools",
        src: tools,
        alt: "Equipo fotográfico profesional de alta gama",
        first: true,
      },
      {
        heading: "Espacios versátiles",
        content: "Trabaja con comodidad en nuestros espaciosos y adaptables sets. Diseñados para acomodar desde retratos íntimos hasta grandes producciones comerciales.",
        svg: "dashboard",
        src: dashboard,
        alt: "Amplios espacios de estudio con diferentes configuraciones",
        second: true,
      },
      {
        heading: "Servicios complementarios",
        content: "Maximiza tu experiencia con nuestros servicios adicionales. Desde asistencia técnica hasta post-producción, ofrecemos todo lo que necesitas para que tu sesión sea un éxito.",
        svg: "house",
        src: construction,
        alt: "Personal asistiendo en una sesión fotográfica",
      },
    ]}
  />

  <TestimonialsSection
    title="Impulsa tu creatividad"
    subTitle="En Content Studio, garantizamos un inicio rápido con reservas instantáneas. Experimenta la eficiencia de la fotografía profesional redefinida."
    testimonials={[
      {
        content: "Content Studio transformó nuestra producción fotográfica. La reserva fue instantánea y la calidad del equipo es excepcional. ¡Un verdadero cambio de juego para nuestros proyectos creativos!",
        author: "Laura Martínez",
        role: "Directora Creativa | Agencia Visión",
        avatarSrc:
          "https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80",
      },
    ]}
    statistics={[
      {
        count: "5000+",
        description: "sesiones realizadas — desde aficionados hasta profesionales reconocidos"
      },
      {
        count: "40%",
        description: "aumento en productividad reportado por nuestros clientes regulares"
      },
      {
        count: "98%",
        description: "tasa de satisfacción en la calidad de nuestros equipos y espacios"
      },
      {
        count: "3x",
        description: "más rápido en setup comparado con estudios tradicionales"
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Preguntas<br />frecuentes" faqs={faqs} />

  <HeroSectionAlt
    title="Crea tu visión con nosotros"
    subTitle="Content Studio es tu socio ideal para llevar tus proyectos fotográficos al siguiente nivel. Reserva tu sesión hoy y descubre la diferencia."
    url="/contact"
  />
</MainLayout>
